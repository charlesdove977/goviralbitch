{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "idea-board-entry.schema.json",
  "title": "Idea Board Entry",
  "description": "Tracks a content idea through the full pipeline lifecycle: idea -> angle -> scripted -> published -> analyzed.",
  "type": "object",
  "required": ["id", "title", "status", "created_at"],
  "properties": {
    "id": { "type": "string", "description": "Unique idea ID (e.g., idea_001)" },
    "title": { "type": "string", "description": "Short title for the idea" },
    "description": { "type": "string", "description": "What the idea is about" },
    "source": {
      "type": "string",
      "description": "Where the idea came from (discover, manual, conversation, competitor, audience, repurpose)"
    },
    "status": {
      "type": "string",
      "enum": ["idea", "angled", "scripted", "published", "analyzed"],
      "description": "Pipeline stage: idea (raw) -> angled (developed) -> scripted (ready to film) -> published (live) -> analyzed (performance reviewed)"
    },
    "platform": {
      "type": "string",
      "enum": ["youtube_longform", "youtube_shorts", "instagram_reels", "instagram_posts", "tiktok", "linkedin", "facebook"],
      "description": "Target platform (may be set later)"
    },
    "pillar": { "type": "string", "description": "Which content pillar this maps to" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"],
      "default": "medium"
    },
    "linked_ids": {
      "type": "object",
      "description": "Links to related pipeline entries",
      "properties": {
        "topic_id": { "type": "string", "description": "Link to topic (if from /discover)" },
        "angle_id": { "type": "string", "description": "Link to angle (if developed)" },
        "script_id": { "type": "string", "description": "Link to script (if scripted)" },
        "analytics_id": { "type": "string", "description": "Link to analytics entry (if analyzed)" }
      },
      "additionalProperties": false
    },
    "history": {
      "type": "array",
      "description": "Append-only status change log",
      "items": {
        "type": "object",
        "required": ["status", "timestamp"],
        "properties": {
          "status": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "published_at": { "type": "string", "format": "date-time" },
    "published_url": { "type": "string", "format": "uri" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags for filtering"
    },
    "notes": { "type": "string" },
    "repurpose_source": {
      "type": "object",
      "description": "Populated when idea was generated by --repurpose mode",
      "required": ["original_id", "original_platform", "strategy"],
      "properties": {
        "original_id": { "type": "string", "description": "Script ID of the source content" },
        "original_platform": { "type": "string", "description": "Platform of original content" },
        "strategy": {
          "type": "string",
          "enum": ["winner_crosspost", "longform_to_clips", "shortform_to_longform", "platform_expand"],
          "description": "Which repurposing strategy generated this"
        },
        "original_title": { "type": "string", "description": "Title of the source script for quick reference" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
